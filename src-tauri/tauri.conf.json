{
  "productName": "Vault",
  "version": "1.0.0",
  "identifier": "com.topolino.vault",
  "build": {
    "frontendDist": "../vault",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src 'self' wss: https:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "Vault",
        "width": 480,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24
    },
    "iOS": {
      "minimumSystemVersion": "16.0"
    }
  }
}
